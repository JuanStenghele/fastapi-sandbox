{
  "title": "Service Overview",
  "uid": "service-overview",
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "query": "local",
        "current": {
          "value": "local",
          "text": "local"
        },
        "options": [
          { "value": "local", "text": "local", "selected": true }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "fastapi-sandbox",
        "current": {
          "value": "fastapi-sandbox",
          "text": "fastapi-sandbox"
        },
        "options": [
          { "value": "fastapi-sandbox", "text": "fastapi-sandbox", "selected": true }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests per Minute",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\"}[1m]))",
          "legendFormat": "Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 7,
      "title": "Top Endpoints",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(20, sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target!=\"\"}[1m])) by (http_target))",
          "legendFormat": "{{http_target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" } },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 8,
      "title": "4xx Errors by Endpoint",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"4..\",http_target!=\"\"}[1m])) by (http_target)",
          "legendFormat": "{{http_target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "shades", "fixedColor": "yellow" },
          "custom": { "drawStyle": "bars", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" } },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 9,
      "title": "5xx Errors by Endpoint",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"5..\",http_target!=\"\"}[1m])) by (http_target)",
          "legendFormat": "{{http_target}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "shades", "fixedColor": "red" },
          "custom": { "drawStyle": "bars", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" } },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"5..\"}[$__range])) / sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\"}[$__range])) * 100",
          "legendFormat": "Error Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "noValue": "0%",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 5    }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "p50 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 200  },
              { "color": "red",    "value": 500  }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "p95 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 300  },
              { "color": "red",    "value": 750  }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "p99 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500  },
              { "color": "red",    "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Requests by Status",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 5,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 10, "spanNulls": true }
        }
      }
    },
    {
      "id": 6,
      "title": "",
      "type": "table",
      "transparent": true,
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "round(sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target!=\"\"}[$__range])) by (http_target))",
          "instant": true,
          "format": "table",
          "refId": "Requests"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target!=\"\"}[$__range])) by (le, http_target))",
          "instant": true,
          "format": "table",
          "refId": "P99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_status_code=~\"5..\",http_target!=\"\"}[$__range])) by (http_target) / sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target!=\"\"}[$__range])) by (http_target) * 100",
          "instant": true,
          "format": "table",
          "refId": "ErrorRate"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "http_target":      "Endpoint",
              "Value #Requests":  "Requests",
              "Value #P99":       "p99 Latency",
              "Value #ErrorRate": "Error Rate"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error Rate" },
            "properties": [
              { "id": "unit",    "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "noValue", "value": "0%" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 1    },
                    { "color": "red",    "value": 5    }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99 Latency" },
            "properties": [
              { "id": "unit", "value": "ms" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 500  },
                    { "color": "red",    "value": 1000 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    }
  ]
}
