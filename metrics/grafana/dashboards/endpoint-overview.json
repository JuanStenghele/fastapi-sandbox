{
  "title": "Endpoint Overview",
  "uid": "endpoint-overview",
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "query": "local",
        "current": {
          "value": "local",
          "text": "local"
        },
        "options": [
          { "value": "local", "text": "local", "selected": true }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "fastapi-sandbox",
        "current": {
          "value": "fastapi-sandbox",
          "text": "fastapi-sandbox"
        },
        "options": [
          { "value": "fastapi-sandbox", "text": "fastapi-sandbox", "selected": true }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\"}, http_target)",
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 8,
      "title": "Total Requests",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 0, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "round(sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[$__range])))",
          "legendFormat": "Requests"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 1,
      "title": "Error Rate",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 5, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\",http_status_code=~\"5..\"}[$__range])) / sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[$__range])) * 100",
          "legendFormat": "Error Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "noValue": "0%",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 5    }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "p50 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 200  },
              { "color": "red",    "value": 500  }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 300  },
              { "color": "red",    "value": 750  }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "p99 Latency",
      "type": "stat",
      "transparent": true,
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500  },
              { "color": "red",    "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Requests per Minute",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m]))",
          "legendFormat": "Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [] }
        }
      }
    },
    {
      "id": 6,
      "title": "Requests by Status",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\",http_status_code=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\",http_status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_duration_milliseconds_count{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\",http_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "drawStyle": "bars", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "transparent": true,
      "options": { "tooltip": { "mode": "multi" } },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$env\",job=\"$service\",http_target=\"$endpoint\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 10, "spanNulls": true }
        }
      }
    }
  ]
}
